<div style="background:#f7f8fc; padding:24px; font-family:Arial, sans-serif; color:#1f2937;">
	<div style="max-width:560px; margin:0 auto; background:#ffffff; border:1px solid #e5e7eb; border-radius:14px; padding:28px;">
		<h2 style="margin:0 0 12px 0; color:#702082; font-size:22px;">Password Reset Request</h2>

		<p style="margin:0 0 12px 0; line-height:1.6;">Hello <%= @user.name || 'student' %>,</p>

		<p style="margin:0 0 14px 0; line-height:1.6;">Use the following one-time password to reset your account password:</p>

		<div style="margin:0 0 16px 0; padding:14px 18px; background:#f5eff8; border:1px dashed #702082; border-radius:10px; text-align:center;">
			<span style="display:inline-block; letter-spacing:4px; font-size:28px; font-weight:700; color:#4d165a;"><%= @otp %></span>
		</div>

		<p style="margin:0 0 10px 0; line-height:1.6;">Enter this code in the app to continue. It expires in <strong>24 hours</strong>.</p>
		<p style="margin:0; line-height:1.6; color:#6b7280; font-size:14px;">If you did not request this change, you can safely ignore this email.</p>
	</div>
</div>
